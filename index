<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Yeonseo Lee — Fashion & Creative Direction</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant:ital,wght@0,200;0,300;0,400;1,200;1,300;1,400&family=Cormorant+Garamond:ital,wght@0,200;0,300;1,200;1,300&family=DM+Sans:wght@200;300;400&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#f7f2ea;
  --bg2:#ede8de;
  --bg3:#e4ddd1;
  --ink:#1a1712;
  --ink2:#3d3830;
  --ink3:rgba(26,23,18,0.45);
  --ink4:rgba(26,23,18,0.22);
  --accent:#9b2020;
  --accent2:#c94040;
  --accent3:#e8c8a0;
  --gold:#c9a96e;
  --serif:'Cormorant','Cormorant Garamond',Georgia,serif;
  --sans:'DM Sans','Helvetica Neue',sans-serif;
  --line:rgba(26,23,18,0.1);
  --line2:rgba(26,23,18,0.18);
  --shadow:rgba(26,23,18,0.12);
}
html{scroll-behavior:smooth;overflow-x:hidden}
body{background:var(--bg);color:var(--ink);font-family:var(--sans);font-weight:300;cursor:none;overflow-x:hidden;-webkit-font-smoothing:antialiased;perspective:1200px}

/* ── CURSOR ── */
#cur{position:fixed;z-index:9999;pointer-events:none;top:0;left:0;will-change:transform}
#cur-dot{position:absolute;width:8px;height:8px;background:var(--accent);border-radius:50%;transform:translate(-50%,-50%);transition:width .25s,height .25s,background .25s}
#cur-ring{position:fixed;z-index:9998;pointer-events:none;width:36px;height:36px;border:1.5px solid var(--accent);border-radius:50%;top:0;left:0;will-change:transform;transition:width .5s cubic-bezier(.16,1,.3,1),height .5s cubic-bezier(.16,1,.3,1),border-color .3s;margin-left:-18px;margin-top:-18px}
.hoverable:hover~#cur-ring{width:60px;height:60px}

/* ── NAV ── */
nav{position:fixed;top:0;left:0;right:0;z-index:800;display:flex;align-items:center;justify-content:space-between;padding:28px 52px;transition:padding .4s,background .4s,backdrop-filter .4s}
nav.solid{background:rgba(247,242,234,0.9);backdrop-filter:blur(20px);padding:16px 52px;border-bottom:1px solid var(--line)}
.nav-logo{font-family:var(--serif);font-size:15px;font-weight:300;letter-spacing:.2em;text-transform:uppercase;color:var(--ink);text-decoration:none;transition:color .3s}
.nav-logo:hover{color:var(--accent)}
.nav-right{display:flex;gap:32px}
.nav-right a{font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--ink3);text-decoration:none;transition:color .3s;font-family:var(--sans)}
.nav-right a:hover{color:var(--accent)}

/* ── HERO ── */
#hero{
  min-height:100vh;position:relative;overflow:hidden;
  display:flex;flex-direction:column;justify-content:center;
  background:var(--bg);
}
/* Animated gradient mesh background */
.hero-mesh{
  position:absolute;inset:0;pointer-events:none;overflow:hidden;
}
.mesh-blob{
  position:absolute;border-radius:50%;filter:blur(80px);opacity:0.35;
  animation:blobFloat 12s ease-in-out infinite alternate;
}
.mesh-blob.b1{width:600px;height:500px;background:radial-gradient(circle,#e8c8a0,transparent 70%);top:-100px;right:-100px;animation-delay:0s}
.mesh-blob.b2{width:500px;height:600px;background:radial-gradient(circle,rgba(155,32,32,0.15),transparent 70%);bottom:-80px;left:-80px;animation-delay:-4s}
.mesh-blob.b3{width:400px;height:400px;background:radial-gradient(circle,#ede8de,transparent 70%);top:40%;left:30%;animation-delay:-8s}
@keyframes blobFloat{from{transform:translate(0,0) scale(1)}to{transform:translate(40px,30px) scale(1.08)}}

/* Hero 3D scene */
.hero-3d-scene{
  position:absolute;right:0;top:0;bottom:0;width:55%;
  perspective:900px;
  display:flex;align-items:center;justify-content:center;
  pointer-events:none;
}
.hero-hanging-stage{
  position:relative;width:100%;height:100%;
  display:flex;align-items:flex-start;justify-content:center;
  padding-top:60px;
  transform-style:preserve-3d;
}
/* The hero rod */
.hero-rod-line{
  position:absolute;top:80px;left:10%;right:10%;height:3px;
  background:linear-gradient(to right,transparent,rgba(26,23,18,0.15) 15%,rgba(26,23,18,0.25) 50%,rgba(26,23,18,0.15) 85%,transparent);
  z-index:2;
}
.hero-rod-line::before,.hero-rod-line::after{
  content:'';position:absolute;top:50%;transform:translateY(-50%);
  width:12px;height:12px;border-radius:50%;border:2px solid rgba(26,23,18,0.2);background:var(--bg);
}
.hero-rod-line::before{left:-6px}
.hero-rod-line::after{right:-6px}

/* Hero floating hangers */
.hero-hanger-group{
  position:absolute;top:60px;
  display:flex;gap:0;
  transform-style:preserve-3d;
}
.hero-hanger-item{
  display:flex;flex-direction:column;align-items:center;
  transform-style:preserve-3d;
  animation:hangerEntrance 1.4s cubic-bezier(.34,1.56,.64,1) both;
}
.hero-hanger-item:nth-child(1){animation-delay:.2s;margin-right:-20px}
.hero-hanger-item:nth-child(2){animation-delay:.45s;margin-right:-20px}
.hero-hanger-item:nth-child(3){animation-delay:.7s;margin-right:-20px}
.hero-hanger-item:nth-child(4){animation-delay:.95s}
@keyframes hangerEntrance{
  0%{opacity:0;transform:translateY(-120px) rotateZ(-25deg)}
  60%{opacity:1}
  80%{transform:translateY(8px) rotateZ(4deg)}
  90%{transform:translateY(-4px) rotateZ(-2deg)}
  100%{transform:translateY(0) rotateZ(0)}
}
/* Continuous gentle swing */
.hero-hanger-item:nth-child(1) .h-hook-wrap{animation:heroSwing1 6s ease-in-out infinite;transform-origin:50% 0}
.hero-hanger-item:nth-child(2) .h-hook-wrap{animation:heroSwing2 7s ease-in-out infinite;transform-origin:50% 0}
.hero-hanger-item:nth-child(3) .h-hook-wrap{animation:heroSwing3 5.5s ease-in-out infinite;transform-origin:50% 0}
.hero-hanger-item:nth-child(4) .h-hook-wrap{animation:heroSwing4 8s ease-in-out infinite;transform-origin:50% 0}
@keyframes heroSwing1{0%,100%{transform:rotateZ(-4deg)}50%{transform:rotateZ(4deg)}}
@keyframes heroSwing2{0%,100%{transform:rotateZ(5deg)}50%{transform:rotateZ(-3deg)}}
@keyframes heroSwing3{0%,100%{transform:rotateZ(-3deg)}50%{transform:rotateZ(6deg)}}
@keyframes heroSwing4{0%,100%{transform:rotateZ(3deg)}50%{transform:rotateZ(-5deg)}}
.h-hook-wrap{display:flex;flex-direction:column;align-items:center}
.h-garment-body{transform-style:preserve-3d}
/* 3D depth on hero garments */
.hero-hanger-item:nth-child(1) .h-garment-body{transform:rotateY(-8deg) rotateX(2deg) translateZ(10px)}
.hero-hanger-item:nth-child(2) .h-garment-body{transform:rotateY(5deg) rotateX(-1deg) translateZ(20px)}
.hero-hanger-item:nth-child(3) .h-garment-body{transform:rotateY(-6deg) rotateX(3deg) translateZ(5px)}
.hero-hanger-item:nth-child(4) .h-garment-body{transform:rotateY(10deg) rotateX(-2deg) translateZ(15px)}

/* Hero text */
.hero-content{
  position:relative;z-index:5;
  padding:0 52px;
  max-width:58%;
}
.hero-eyebrow{
  font-size:10px;letter-spacing:.32em;text-transform:uppercase;
  color:var(--ink3);margin-bottom:24px;
  font-family:var(--sans);
  animation:fadeUp .8s .1s both;
}
.hero-name{
  font-family:var(--serif);
  font-size:clamp(70px,12vw,188px);
  font-weight:200;line-height:.88;
  letter-spacing:-.02em;
  color:var(--ink);
  animation:fadeUp .9s .2s both;
}
.hero-name em{font-style:italic;color:var(--accent)}
.hero-tagline{
  font-family:var(--serif);
  font-size:clamp(16px,2.2vw,28px);
  font-weight:200;font-style:italic;
  color:var(--ink3);margin-top:20px;
  letter-spacing:.02em;
  animation:fadeUp .9s .4s both;
}
.hero-sub-row{
  display:flex;align-items:center;gap:32px;
  margin-top:40px;
  border-top:1px solid var(--line);
  padding-top:28px;
  animation:fadeUp .9s .55s both;
}
.hero-badge{
  font-size:9.5px;letter-spacing:.22em;text-transform:uppercase;
  color:var(--ink3);font-family:var(--sans);
}
.hero-badge strong{color:var(--accent);font-weight:400}
.hero-cta{
  display:inline-flex;align-items:center;gap:12px;
  font-size:10px;letter-spacing:.22em;text-transform:uppercase;
  color:var(--ink);border-bottom:1.5px solid var(--ink);
  padding-bottom:4px;text-decoration:none;
  transition:color .3s,border-color .3s;
  font-family:var(--sans);
}
.hero-cta:hover{color:var(--accent);border-color:var(--accent)}
.hero-cta .arr{transition:transform .4s cubic-bezier(.34,1.56,.64,1)}
.hero-cta:hover .arr{transform:translateX(5px)}
@keyframes fadeUp{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:translateY(0)}}

/* Scroll indicator */
.scroll-ind{
  position:absolute;bottom:36px;left:52px;
  display:flex;align-items:center;gap:12px;
  animation:fadeUp 1s .9s both;
}
.scroll-ind span{font-size:9px;letter-spacing:.24em;text-transform:uppercase;color:var(--ink3);font-family:var(--sans)}
.scroll-ind-line{width:50px;height:1px;background:var(--line2);position:relative;overflow:hidden}
.scroll-ind-line::after{content:'';position:absolute;inset:0;background:var(--accent);animation:sweepLine 2.4s ease-in-out infinite}
@keyframes sweepLine{0%{transform:translateX(-100%)}100%{transform:translateX(200%)}})

/* ── SECTION BASICS ── */
.section-rule{height:1px;background:var(--line);margin:0 52px}
.chapter{padding:112px 52px}
.chapter-index{font-size:9.5px;letter-spacing:.3em;text-transform:uppercase;color:var(--ink3);margin-bottom:44px;display:flex;align-items:center;gap:20px;font-family:var(--sans)}
.chapter-index::after{content:'';flex:1;height:1px;background:var(--line)}
.chapter-heading{font-family:var(--serif);font-size:clamp(56px,9vw,138px);font-weight:200;line-height:.92;letter-spacing:-.02em}
.chapter-heading em{font-style:italic;color:var(--accent)}
.reveal{opacity:0;transform:translateY(24px);transition:opacity 1s cubic-bezier(.16,1,.3,1),transform 1s cubic-bezier(.16,1,.3,1)}
.reveal.in{opacity:1;transform:none}
.d1{transition-delay:.12s}.d2{transition-delay:.26s}.d3{transition-delay:.42s}.d4{transition-delay:.58s}.d5{transition-delay:.74s}

/* ── ABOUT ── */
#about{background:var(--bg2)}
#about .about-grid{display:grid;grid-template-columns:1fr 1fr;border-top:1px solid var(--line)}
.about-col{padding:64px 52px}
.about-col+.about-col{border-left:1px solid var(--line);background:var(--bg)}
.about-label{font-size:9px;letter-spacing:.28em;text-transform:uppercase;color:var(--ink3);margin-bottom:24px;font-family:var(--sans)}
.about-quote{
  font-family:var(--serif);font-size:clamp(18px,2.4vw,30px);font-style:italic;font-weight:200;
  color:var(--ink);border-left:2px solid var(--accent);padding-left:24px;
  margin:32px 0;line-height:1.5;letter-spacing:.01em;
}
.about-body{font-size:14.5px;font-weight:300;line-height:1.9;color:var(--ink2);letter-spacing:.01em;font-family:var(--sans)}
.about-body+.about-body{margin-top:18px}
.about-body strong{color:var(--ink);font-weight:400}
.about-body em{font-style:italic;color:var(--accent)}
.skills-grid{margin-top:44px;display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--line);border:1px solid var(--line)}
.skill-cell{background:var(--bg2);padding:14px 18px;font-size:9.5px;letter-spacing:.15em;text-transform:uppercase;color:var(--ink3);transition:all .3s;font-family:var(--sans)}
.skill-cell:hover{background:var(--accent);color:white;letter-spacing:.2em}
.edu-entry{padding:20px 0;border-bottom:1px solid var(--line)}
.edu-entry:first-child{border-top:1px solid var(--line)}
.edu-school{font-family:var(--serif);font-size:20px;font-weight:300;color:var(--ink);margin-bottom:4px}
.edu-degree{font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--ink3);margin-bottom:5px;font-family:var(--sans)}
.edu-gpa{font-family:var(--serif);font-size:15px;font-style:italic;color:var(--accent)}

/* ── PROJECTS ── 3D card tilt grid ── */
#projects{background:var(--bg);padding-bottom:120px}
.projects-header{padding:112px 52px 0}
.proj-grid{
  display:grid;grid-template-columns:1fr 1fr 1fr;
  gap:2px;background:var(--line);
  margin-top:64px;
}
.proj-card{
  background:var(--bg2);
  padding:48px 40px;
  position:relative;overflow:hidden;
  cursor:none;
  transition:background .4s;
  transform-style:preserve-3d;
  will-change:transform;
}
.proj-card::before{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(201,160,110,0.08) 0%,transparent 60%);
  opacity:0;transition:opacity .4s;
}
.proj-card:hover{background:var(--ink)}
.proj-card:hover::before{opacity:1}
.proj-card:hover .pc-num,.proj-card:hover .pc-meta{color:rgba(247,242,234,.35)}
.proj-card:hover .pc-name{color:var(--bg)}
.proj-card:hover .pc-desc{color:rgba(247,242,234,.55)}
.proj-card:hover .pc-arrow{color:var(--accent2);transform:translate(4px,-4px) scale(1.1)}
.pc-num{font-size:10px;letter-spacing:.24em;text-transform:uppercase;color:var(--ink3);margin-bottom:32px;transition:color .4s;font-family:var(--sans)}
.pc-name{font-family:var(--serif);font-size:clamp(22px,2.5vw,34px);font-weight:200;line-height:1.1;letter-spacing:-.01em;margin-bottom:16px;transition:color .4s}
.pc-meta{font-size:9px;letter-spacing:.18em;text-transform:uppercase;color:var(--ink3);margin-bottom:20px;transition:color .4s;font-family:var(--sans)}
.pc-desc{font-size:13px;line-height:1.85;color:var(--ink2);font-weight:300;transition:color .4s;font-family:var(--sans);max-width:280px}
.pc-arrow{position:absolute;top:40px;right:40px;font-size:20px;color:var(--ink4);transition:all .4s cubic-bezier(.34,1.56,.64,1)}
.pc-sketch{position:absolute;bottom:32px;right:32px;opacity:0.07;transition:opacity .4s,transform .4s}
.proj-card:hover .pc-sketch{opacity:0.18;transform:scale(1.05) rotate(3deg)}
.proj-tag-ip{font-size:8px;letter-spacing:.2em;text-transform:uppercase;color:var(--accent2);border:1px solid var(--accent);padding:3px 8px;margin-left:8px;vertical-align:middle;font-family:var(--sans)}

/* ── CLOSET — THE SPECTACULAR SECTION ── */
#closet{
  background:var(--bg3);
  padding:0;overflow:hidden;
  position:relative;
}
.closet-chapter{padding:100px 52px 70px}
.closet-heading{font-family:var(--serif);font-size:clamp(54px,8.5vw,132px);font-weight:200;line-height:.92;letter-spacing:-.02em}
.closet-heading em{font-style:italic;color:var(--accent)}
/* Giant decorative rod - full width */
.closet-rod-full{
  position:relative;margin:0 52px;
  height:4px;
  background:linear-gradient(to right,transparent,var(--ink4) 5%,var(--ink2) 30%,var(--ink) 50%,var(--ink2) 70%,var(--ink4) 95%,transparent);
  border-radius:2px;
  box-shadow:0 4px 20px var(--shadow),0 1px 0 rgba(255,255,255,0.6);
}
.closet-rod-full::before,.closet-rod-full::after{
  content:'';position:absolute;top:50%;transform:translateY(-50%);
  width:16px;height:16px;border-radius:50%;
  background:var(--ink2);box-shadow:inset 0 2px 4px rgba(0,0,0,.3),0 2px 6px var(--shadow);
}
.closet-rod-full::before{left:-8px}
.closet-rod-full::after{right:-8px}
/* Ceiling wire */
.rod-wire{
  position:absolute;bottom:100%;left:50%;
  width:1px;height:40px;background:var(--ink4);
  transform:translateX(-50%);
}
/* Closet track */
.closet-outer{overflow:hidden;position:relative}
.closet-track-3d{
  display:flex;
  overflow-x:auto;scrollbar-width:none;
  cursor:grab;
  padding:0 52px 80px;
  perspective:1200px;
  gap:32px;
}
.closet-track-3d:active{cursor:grabbing}
.closet-track-3d::-webkit-scrollbar{display:none}
/* Each hanger with full 3D */
.hanger3d{
  flex:0 0 200px;
  display:flex;flex-direction:column;align-items:center;
  cursor:none;
  transform-style:preserve-3d;
  will-change:transform;
}
/* Entrance animation - drop from above */
.hanger3d{
  animation:dropIn 0.9s cubic-bezier(.34,1.3,.64,1) both;
}
.hanger3d:nth-child(1){animation-delay:.05s}
.hanger3d:nth-child(2){animation-delay:.18s}
.hanger3d:nth-child(3){animation-delay:.32s}
.hanger3d:nth-child(4){animation-delay:.46s}
.hanger3d:nth-child(5){animation-delay:.60s}
@keyframes dropIn{
  0%{opacity:0;transform:translateY(-180px) rotateZ(-30deg) scale(.7)}
  70%{opacity:1}
  85%{transform:translateY(10px) rotateZ(5deg) scale(1.02)}
  95%{transform:translateY(-5px) rotateZ(-2deg) scale(.99)}
  100%{transform:translateY(0) rotateZ(0) scale(1)}
}
.hanger3d-hook-wrap{
  transform-style:preserve-3d;
  transform-origin:50% 0;
}
/* Idle pendulum swing per hanger */
.hanger3d:nth-child(1) .hanger3d-hook-wrap{animation:swing3d1 7s ease-in-out infinite;transform-origin:50% 2px}
.hanger3d:nth-child(2) .hanger3d-hook-wrap{animation:swing3d2 8.5s ease-in-out infinite;transform-origin:50% 2px}
.hanger3d:nth-child(3) .hanger3d-hook-wrap{animation:swing3d3 6s ease-in-out infinite;transform-origin:50% 2px}
.hanger3d:nth-child(4) .hanger3d-hook-wrap{animation:swing3d4 9s ease-in-out infinite;transform-origin:50% 2px}
.hanger3d:nth-child(5) .hanger3d-hook-wrap{animation:swing3d5 7.5s ease-in-out infinite;transform-origin:50% 2px}
@keyframes swing3d1{0%,100%{transform:rotateZ(-6deg) rotateY(-5deg)}50%{transform:rotateZ(6deg) rotateY(4deg)}}
@keyframes swing3d2{0%,100%{transform:rotateZ(7deg) rotateY(6deg)}50%{transform:rotateZ(-5deg) rotateY(-3deg)}}
@keyframes swing3d3{0%,100%{transform:rotateZ(-4deg) rotateY(3deg)}50%{transform:rotateZ(8deg) rotateY(-6deg)}}
@keyframes swing3d4{0%,100%{transform:rotateZ(5deg) rotateY(-4deg)}50%{transform:rotateZ(-7deg) rotateY(5deg)}}
@keyframes swing3d5{0%,100%{transform:rotateZ(-8deg) rotateY(6deg)}50%{transform:rotateZ(4deg) rotateY(-3deg)}}
/* Hover: freeze swing + big 3D tilt toward viewer */
.hanger3d:hover .hanger3d-hook-wrap{
  animation:none !important;
  transform:rotateZ(0) rotateY(0) scale(1.06) translateZ(30px) !important;
  transition:transform .5s cubic-bezier(.16,1,.3,1);
}
.hanger3d:hover{z-index:10}
/* Garment card 3D */
.hanger3d-garment{
  width:170px;margin-top:-2px;
  position:relative;
  transform-style:preserve-3d;
  transition:box-shadow .4s;
}
.hanger3d:hover .hanger3d-garment{
  box-shadow:0 24px 60px rgba(26,23,18,0.18),0 8px 20px rgba(26,23,18,0.1);
}
.garment-card3d{
  width:170px;
  background:var(--bg);
  border:1px solid rgba(26,23,18,0.08);
  position:relative;overflow:hidden;
  transform-style:preserve-3d;
}
.garment-card3d::after{
  content:'';position:absolute;top:0;left:0;right:0;height:40%;
  background:linear-gradient(to bottom,rgba(255,255,255,0.18),transparent);
  pointer-events:none;
}
/* Shadow under garment */
.garment-shadow{
  width:130px;height:14px;
  background:radial-gradient(ellipse,rgba(26,23,18,0.2),transparent 70%);
  margin-top:6px;
  transition:width .5s,opacity .5s;
}
.hanger3d:hover .garment-shadow{width:150px;opacity:0.7}
.hanger3d-info{margin-top:18px;text-align:center;padding:0 8px}
.hanger3d-name{font-family:var(--serif);font-size:16px;font-weight:300;color:var(--ink);display:block;margin-bottom:3px;letter-spacing:.04em}
.hanger3d-sub{font-size:8.5px;letter-spacing:.2em;text-transform:uppercase;color:var(--ink3);font-family:var(--sans)}
/* Price tag 3D effect */
.price3d{
  position:absolute;top:12px;right:-12px;
  width:26px;height:40px;
  background:var(--bg3);
  border:1px solid rgba(26,23,18,0.12);
  display:flex;align-items:center;justify-content:center;
  transform:rotateY(-30deg) translateZ(5px);
  box-shadow:3px 3px 8px rgba(26,23,18,.1);
}
.price3d span{writing-mode:vertical-rl;font-size:6px;letter-spacing:.12em;text-transform:uppercase;color:var(--ink3);font-family:var(--sans)}
/* Drag hint */
.drag-hint3d{
  padding:0 52px 32px;
  font-size:9px;letter-spacing:.22em;text-transform:uppercase;
  color:var(--ink3);display:flex;align-items:center;gap:12px;
  font-family:var(--sans);
}
.drag-hint3d::before{content:'← →';letter-spacing:-.05em;font-size:14px;color:var(--accent)}

/* ── CAREERS ── */
#careers{background:var(--bg2)}
.careers-list{border-top:1px solid var(--line)}
.career-row{
  display:grid;grid-template-columns:240px 1fr;
  align-items:start;padding:44px 52px;
  border-bottom:1px solid var(--line);
  transition:background .4s;
  position:relative;overflow:hidden;
}
.career-row::after{
  content:'';position:absolute;left:0;top:0;bottom:0;width:3px;
  background:var(--accent);transform:scaleY(0);transition:transform .4s cubic-bezier(.16,1,.3,1);transform-origin:bottom;
}
.career-row:hover{background:var(--bg)}
.career-row:hover::after{transform:scaleY(1)}
.career-period{font-size:9.5px;letter-spacing:.15em;text-transform:uppercase;color:var(--ink3);padding-top:5px;font-family:var(--sans);line-height:1.7}
.career-loc{font-size:9px;color:var(--ink4);margin-top:6px;letter-spacing:.12em;text-transform:uppercase;font-family:var(--sans)}
.career-company{font-size:9.5px;letter-spacing:.2em;text-transform:uppercase;color:var(--accent);margin-bottom:8px;font-family:var(--sans)}
.career-role{font-family:var(--serif);font-size:clamp(22px,3vw,38px);font-weight:200;line-height:1;letter-spacing:-.01em;margin-bottom:14px}
.career-desc{font-size:13px;font-weight:300;line-height:1.88;color:var(--ink2);max-width:520px;letter-spacing:.01em;font-family:var(--sans)}

/* ── STRATEGY — 3D FLIP CARDS ── */
#strategy{background:var(--bg);padding:0 0 120px}
.strat-grid{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:24px;padding:64px 52px 0;
}
.flip-card{
  height:380px;perspective:800px;cursor:none;
}
.flip-inner{
  width:100%;height:100%;
  transform-style:preserve-3d;
  transition:transform .8s cubic-bezier(.16,1,.3,1);
  position:relative;
}
.flip-card:hover .flip-inner{transform:rotateY(180deg)}
.flip-front,.flip-back{
  position:absolute;inset:0;
  backface-visibility:hidden;
  padding:44px 36px;
  border:1px solid var(--line2);
}
.flip-front{
  background:var(--bg2);
  display:flex;flex-direction:column;justify-content:space-between;
}
.flip-back{
  background:var(--ink);
  transform:rotateY(180deg);
  display:flex;flex-direction:column;justify-content:space-between;
}
.flip-num{font-family:var(--serif);font-size:80px;font-weight:200;line-height:.85;color:rgba(26,23,18,.07);letter-spacing:-.02em;margin-bottom:16px}
.flip-cat{font-size:8.5px;letter-spacing:.24em;text-transform:uppercase;color:var(--accent);margin-bottom:12px;font-family:var(--sans)}
.flip-title{font-family:var(--serif);font-size:clamp(20px,2.4vw,30px);font-weight:200;line-height:1.15;letter-spacing:-.01em}
.flip-title em{font-style:italic}
.flip-hint{font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:var(--ink3);font-family:var(--sans);display:flex;align-items:center;gap:8px}
.flip-hint::after{content:'↻';font-size:14px}
/* Back */
.flip-back-cat{font-size:8.5px;letter-spacing:.24em;text-transform:uppercase;color:var(--accent2);font-family:var(--sans);margin-bottom:12px}
.flip-back-title{font-family:var(--serif);font-size:24px;font-weight:200;color:var(--bg);line-height:1.15;margin-bottom:20px;letter-spacing:-.01em}
.flip-back-title em{font-style:italic}
.flip-desc{font-size:12.5px;line-height:1.88;color:rgba(247,242,234,.58);font-weight:300;font-family:var(--sans)}
.flip-tags{display:flex;flex-wrap:wrap;gap:7px;margin-top:20px}
.flip-tag{font-size:7.5px;letter-spacing:.16em;text-transform:uppercase;border:1px solid rgba(247,242,234,.18);padding:5px 10px;color:rgba(247,242,234,.45);font-family:var(--sans)}

/* ── AWARDS ── */
#awards{background:var(--bg3)}
.awards-row{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:2px;background:var(--line);
  border-top:1px solid var(--line);
  margin-top:0;
}
.award-cell{
  background:var(--bg2);padding:52px 44px;
  transition:all .5s cubic-bezier(.16,1,.3,1);
  position:relative;overflow:hidden;
  transform-style:preserve-3d;
}
.award-cell::before{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,var(--accent) 0%,rgba(155,32,32,0.85) 100%);
  opacity:0;transition:opacity .5s;
}
.award-cell:hover::before{opacity:1}
.award-cell:hover .award-prize,.award-cell:hover .award-title,.award-cell:hover .award-org,.award-cell:hover .award-year{color:var(--bg);position:relative;z-index:1}
.award-cell:hover .award-cat{color:rgba(247,242,234,.6);position:relative;z-index:1}
.award-cell:hover{transform:translateY(-8px) scale(1.02);box-shadow:0 24px 60px rgba(155,32,32,.25)}
.award-prize{font-family:var(--serif);font-size:clamp(32px,4.5vw,60px);font-weight:200;line-height:1;color:rgba(26,23,18,.1);margin-bottom:22px;letter-spacing:-.01em;position:relative;z-index:1;transition:color .5s}
.award-cat{font-size:8.5px;letter-spacing:.22em;text-transform:uppercase;color:var(--accent);margin-bottom:10px;font-family:var(--sans);position:relative;z-index:1;transition:color .5s}
.award-title{font-family:var(--serif);font-size:20px;font-weight:300;line-height:1.25;margin-bottom:8px;position:relative;z-index:1;transition:color .5s}
.award-org{font-size:10px;letter-spacing:.13em;text-transform:uppercase;color:var(--ink3);font-family:var(--sans);position:relative;z-index:1;transition:color .5s;line-height:1.6}
.award-year{font-family:var(--serif);font-size:14px;font-style:italic;color:var(--ink3);margin-top:8px;position:relative;z-index:1;transition:color .5s}

/* ── CONTACT ── */
#contact{
  background:var(--bg);min-height:85vh;
  display:flex;flex-direction:column;justify-content:center;
  padding:0 52px;text-align:center;position:relative;overflow:hidden;
}
/* Animated background hangers */
.contact-bg-hangers{
  position:absolute;inset:0;pointer-events:none;overflow:hidden;
  opacity:0.06;
}
.contact-heading{font-family:var(--serif);font-size:clamp(54px,9vw,128px);font-weight:200;line-height:.9;letter-spacing:-.02em;margin-bottom:52px;position:relative;z-index:2}
.contact-heading em{font-style:italic;color:var(--accent)}
.contact-eyebrow{font-size:9.5px;letter-spacing:.3em;text-transform:uppercase;color:var(--ink3);margin-bottom:32px;position:relative;z-index:2;font-family:var(--sans)}
.contact-note{font-family:var(--serif);font-size:18px;font-style:italic;color:var(--ink3);margin-bottom:32px;font-weight:200;position:relative;z-index:2}
.contact-avail{
  display:inline-block;font-size:9.5px;letter-spacing:.18em;text-transform:uppercase;
  border:1px solid var(--line2);padding:11px 22px;
  color:var(--ink3);font-family:var(--sans);margin-top:40px;
  position:relative;z-index:2;transition:all .3s;
}
.contact-avail:hover{background:var(--accent);border-color:var(--accent);color:white}
.contact-link{font-family:var(--serif);font-size:clamp(16px,2.1vw,28px);font-weight:300;letter-spacing:.08em;color:var(--ink);text-decoration:none;border-bottom:1.5px solid var(--line2);padding-bottom:5px;transition:all .3s;position:relative;z-index:2}
.contact-link:hover{border-color:var(--accent);color:var(--accent)}
.contact-socials{display:flex;gap:28px;justify-content:center;margin-top:40px;position:relative;z-index:2}
.contact-socials a{font-size:9px;letter-spacing:.22em;text-transform:uppercase;color:var(--ink3);text-decoration:none;transition:color .3s;font-family:var(--sans)}
.contact-socials a:hover{color:var(--accent)}
.contact-socials span{color:var(--line2)}

/* ── FOOTER ── */
footer{padding:26px 52px;display:flex;align-items:center;justify-content:space-between;border-top:1px solid var(--line);background:var(--bg2)}
footer span{font-size:9px;letter-spacing:.18em;text-transform:uppercase;color:var(--ink3);font-family:var(--sans)}

/* ── MODAL ── */
.modal{position:fixed;inset:0;z-index:1000;opacity:0;pointer-events:none;transition:opacity .6s cubic-bezier(.16,1,.3,1);overflow-y:auto;background:var(--bg)}
.modal.open{opacity:1;pointer-events:all}
.modal-inner{max-width:900px;margin:0 auto;padding:80px 52px 120px;}
.modal-close{position:fixed;top:32px;right:44px;z-index:1001;background:none;border:1.5px solid var(--line2);width:40px;height:40px;cursor:none;display:flex;align-items:center;justify-content:center;transition:all .3s;color:var(--ink)}
.modal-close:hover{background:var(--accent);border-color:var(--accent);color:white}
.modal-eyebrow{font-size:9px;letter-spacing:.28em;text-transform:uppercase;color:var(--ink3);margin-bottom:16px;font-family:var(--sans)}
.modal-h{font-family:var(--serif);font-size:clamp(36px,5vw,72px);font-weight:200;line-height:1;letter-spacing:-.015em;margin-bottom:12px;color:var(--ink)}
.modal-divider{border:none;border-top:1px solid var(--line);margin:32px 0;}
.modal-gallery{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:6px;margin:28px 0;}
.modal-gallery img{width:100%;aspect-ratio:3/4;object-fit:cover;display:block;}
.modal-gallery img.landscape{aspect-ratio:4/3;}
.modal-desc-grid{display:grid;grid-template-columns:1fr 1fr;gap:40px;margin-top:32px;align-items:start;}
.modal-sec{font-size:8.5px;letter-spacing:.24em;text-transform:uppercase;color:var(--accent);margin-bottom:12px;font-family:var(--sans)}
.modal-p{font-size:13.5px;font-weight:300;line-height:1.92;color:var(--ink2);letter-spacing:.01em;font-family:var(--sans);white-space:pre-wrap;word-break:break-word;}
.modal-tag{display:inline-block;font-size:8px;letter-spacing:.16em;text-transform:uppercase;border:1px solid var(--line2);padding:5px 10px;color:var(--ink3);margin:4px 4px 0 0;font-family:var(--sans)}

/* ── RESPONSIVE ── */
@media(max-width:960px){
  nav,nav.solid{padding:18px 22px}
  .nav-right{display:none}
  .hero-content{max-width:100%;padding:0 22px}
  .hero-3d-scene{display:none}
  .chapter,.closet-chapter{padding:64px 22px}
  #about .about-grid,.modal-inner{grid-template-columns:1fr}
  .about-col+.about-col{border-left:none;border-top:1px solid var(--line)}
  .about-col{padding:40px 22px}
  .proj-grid{grid-template-columns:1fr}
  .strat-grid{grid-template-columns:1fr;padding:40px 22px 0}
  .awards-row{grid-template-columns:1fr}
  .career-row{grid-template-columns:1fr;padding:32px 22px}
  .career-period{display:none}
  .closet-rod-full,.drag-hint3d{margin-left:22px;margin-right:22px;padding-left:22px;padding-right:22px}
  .closet-track-3d{padding:0 22px 60px}
  .section-rule{margin:0 22px}
  .modal-left{display:none}
  .modal-right{padding:60px 22px}
  .modal-inner{padding:60px 22px 80px;}
  .modal-desc-grid{grid-template-columns:1fr;}
  footer{padding:20px 22px;flex-direction:column;gap:8px;text-align:center}
  #contact{padding:0 22px}
  .scroll-ind{left:22px}
}
</style>
</head>
