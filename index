<div class="modal" id="modal">
  <button class="modal-close" onclick="closeModal()">
    <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 1l11 11M12 1L1 12"/></svg>
  </button>
  <div class="modal-inner" id="modal-inner"></div>
</div>

<script>
/* ── CURSOR ── */
const dot=document.getElementById('cur'),ring=document.getElementById('cur-ring');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY});
(function raf(){
  dot.style.transform=`translate(${mx}px,${my}px)`;
  rx+=(mx-rx)*.1;ry+=(my-ry)*.1;
  ring.style.transform=`translate(${rx}px,${ry}px)`;
  requestAnimationFrame(raf);
})();

/* ── NAV ── */
const nav=document.getElementById('nav');
window.addEventListener('scroll',()=>nav.classList.toggle('solid',scrollY>80),{passive:true});

/* ── REVEAL OBSERVER ── */
const rObs=new IntersectionObserver(e=>e.forEach(x=>{if(x.isIntersecting){x.target.classList.add('in');rObs.unobserve(x.target)}}),{threshold:0.08});
document.querySelectorAll('.panel,.reveal').forEach(el=>rObs.observe(el));

/* ── 3D TILT on proj cards ── */
document.querySelectorAll('.proj-card').forEach(card=>{
  card.addEventListener('mousemove',e=>{
    const r=card.getBoundingClientRect();
    const cx=(e.clientX-r.left)/r.width-.5;
    const cy=(e.clientY-r.top)/r.height-.5;
    card.style.transform=`perspective(600px) rotateY(${cx*14}deg) rotateX(${-cy*10}deg) translateZ(8px)`;
  });
  card.addEventListener('mouseleave',()=>{
    card.style.transition='transform .6s cubic-bezier(.16,1,.3,1),background .4s';
    card.style.transform='perspective(600px) rotateY(0) rotateX(0) translateZ(0)';
    setTimeout(()=>card.style.transition='',600);
  });
});

/* ── 3D TILT on hero scene ── */
const heroScene=document.getElementById('hero3dScene');
if(heroScene){
  document.getElementById('hero').addEventListener('mousemove',e=>{
    const r=heroScene.getBoundingClientRect();
    const cx=(e.clientX-r.left-r.width/2)/r.width;
    const cy=(e.clientY-r.top-r.height/2)/r.height;
    heroScene.querySelector('.hero-hanging-stage').style.transform=
      `perspective(900px) rotateY(${cx*8}deg) rotateX(${-cy*5}deg)`;
  });
  document.getElementById('hero').addEventListener('mouseleave',()=>{
    const stage=heroScene.querySelector('.hero-hanging-stage');
    stage.style.transition='transform .8s cubic-bezier(.16,1,.3,1)';
    stage.style.transform='perspective(900px) rotateY(0) rotateX(0)';
  });
}

/* ── CLOSET DRAG ── */
const track=document.getElementById('closetTrack');
let down=false,sx=0,sl=0;
track.addEventListener('mousedown',e=>{down=true;sx=e.pageX-track.offsetLeft;sl=track.scrollLeft;track.style.cursor='grabbing'});
['mouseleave','mouseup'].forEach(ev=>track.addEventListener(ev,()=>{down=false;track.style.cursor='grab'}));
track.addEventListener('mousemove',e=>{if(!down)return;e.preventDefault();track.scrollLeft=sl-(e.pageX-track.offsetLeft-sx)*1.5});
let ts=0,tsl=0;
track.addEventListener('touchstart',e=>{ts=e.touches[0].pageX;tsl=track.scrollLeft},{passive:true});
track.addEventListener('touchmove',e=>{track.scrollLeft=tsl-(e.touches[0].pageX-ts)},{passive:true});

/* ── CLOSET HANGER 3D TILT ── */
document.querySelectorAll('.hanger3d').forEach(h=>{
  h.addEventListener('mousemove',e=>{
    const r=h.getBoundingClientRect();
    const cx=(e.clientX-r.left)/r.width-.5;
    const cy=(e.clientY-r.top)/r.height-.5;
    const garment=h.querySelector('.garment-card3d');
    if(garment){
      garment.style.transform=`perspective(500px) rotateY(${cx*20}deg) rotateX(${-cy*12}deg) translateZ(16px)`;
      garment.style.transition='transform .15s ease';
    }
  });
  h.addEventListener('mouseleave',()=>{
    const garment=h.querySelector('.garment-card3d');
    if(garment){
      garment.style.transition='transform .6s cubic-bezier(.16,1,.3,1)';
      garment.style.transform='perspective(500px) rotateY(0) rotateX(0) translateZ(0)';
    }
  });
});

/* ── AWARD 3D TILT ── */
document.querySelectorAll('.award-cell').forEach(cell=>{
  cell.addEventListener('mousemove',e=>{
    const r=cell.getBoundingClientRect();
    const cx=(e.clientX-r.left)/r.width-.5;
    const cy=(e.clientY-r.top)/r.height-.5;
    cell.style.transform=`translateY(-8px) scale(1.02) perspective(400px) rotateY(${cx*8}deg) rotateX(${-cy*6}deg)`;
  });
  cell.addEventListener('mouseleave',()=>{
    cell.style.transform='';
  });
});

/* ── SCROLL PARALLAX on hero mesh blobs ── */
window.addEventListener('scroll',()=>{
  const y=scrollY;
  const blobs=document.querySelectorAll('.mesh-blob');
  if(blobs[0]) blobs[0].style.transform=`translate(${y*.04}px,${-y*.06}px) scale(1)`;
  if(blobs[1]) blobs[1].style.transform=`translate(${-y*.03}px,${y*.05}px) scale(1)`;
},{passive:true});

/* ── PROJECT DATA (Notion에서 불러옴) ── */
let projects = [];

function renderProjects() {
  const grid = document.querySelector('.proj-grid');
  if (!grid) return;
  if (projects.length === 0) {
    grid.innerHTML = '<p style="padding:48px;color:var(--ink3);font-family:var(--sans);font-size:13px;letter-spacing:.1em;">Loading projects...</p>';
    return;
  }
  grid.innerHTML = projects.map((p, i) => `
    <div class="proj-card" onclick="openModal(${i})">
      <p class="pc-num">0${i + 1}</p>
      ${p.thumbnail ? `<img src="${p.thumbnail}" alt="${p.titleEN}" style="width:100%;height:180px;object-fit:cover;margin-bottom:20px;opacity:0.85;">` : ''}
      <h3 class="pc-name">${p.titleEN}${p.titleKR ? `<br><span style="font-size:0.7em;opacity:0.6;">${p.titleKR}</span>` : ''}</h3>
      <p class="pc-meta">${p.category}${p.year ? ' · ' + p.year : ''}</p>
      <p class="pc-desc">${p.descriptionEN}</p>
      <span class="pc-arrow">↗</span>
    </div>
  `).join('');

  /* 3D tilt 재적용 */
  document.querySelectorAll('.proj-card').forEach(card=>{
    card.addEventListener('mousemove',e=>{
      const r=card.getBoundingClientRect();
      const cx=(e.clientX-r.left)/r.width-.5;
      const cy=(e.clientY-r.top)/r.height-.5;
      card.style.transform=`perspective(600px) rotateY(${cx*14}deg) rotateX(${-cy*10}deg) translateZ(8px)`;
    });
    card.addEventListener('mouseleave',()=>{
      card.style.transition='transform .6s cubic-bezier(.16,1,.3,1),background .4s';
      card.style.transform='perspective(600px) rotateY(0) rotateX(0) translateZ(0)';
      setTimeout(()=>card.style.transition='',600);
    });
  });
}

async function loadProjects() {
  try {
    const res = await fetch('/api/projects');
    const data = await res.json();
    projects = data.projects || [];
    renderProjects();
  } catch(e) {
    console.error('Notion 로드 실패:', e);
    const grid = document.querySelector('.proj-grid');
    if (grid) grid.innerHTML = '<p style="padding:48px;color:var(--ink3);font-family:var(--sans);font-size:13px;">프로젝트를 불러올 수 없습니다.</p>';
  }
}

loadProjects();

/* ── MODAL ── */
function openModal(i){
  const p=projects[i];
  if(!p) return;

  const toHtml = (str) => str ? str.replace(/\n/g, '<br>') : '';

  const galleryHtml = p.detailImages && p.detailImages.length
    ? `<div class="modal-gallery">${p.detailImages.map(url=>`<img src="${url}" alt="${p.titleEN}">`).join('')}</div>`
    : p.thumbnail
      ? `<div class="modal-gallery"><img src="${p.thumbnail}" alt="${p.titleEN}" style="grid-column:1/-1;aspect-ratio:16/9;"></div>`
      : '';

  const descHtml = (p.descriptionEN || p.descriptionKR)
    ? `<hr class="modal-divider">
       <div class="modal-desc-grid">
         ${p.descriptionEN ? `<div><p class="modal-sec">Description</p><p class="modal-p">${toHtml(p.descriptionEN)}</p></div>` : ''}
         ${p.descriptionKR ? `<div><p class="modal-sec">설명</p><p class="modal-p">${toHtml(p.descriptionKR)}</p></div>` : ''}
       </div>`
    : '';

  document.getElementById('modal-inner').innerHTML=`
    <p class="modal-eyebrow">${p.category}${p.year ? ' · ' + p.year : ''}</p>
    <h2 class="modal-h">${p.titleEN}</h2>
    ${p.titleKR ? `<p style="font-family:var(--serif);font-size:17px;font-style:italic;color:var(--ink3);margin-bottom:16px;">${p.titleKR}</p>` : ''}
    <span class="modal-tag">${p.category}</span>
    ${galleryHtml}
    ${descHtml}
  `;

  document.getElementById('modal').classList.add('open');
  document.body.style.overflow='hidden';
  setTimeout(()=>{ document.getElementById('modal').scrollTop=0; }, 10);
}
function closeModal(){document.getElementById('modal').classList.remove('open');document.body.style.overflow=''}
document.addEventListener('keydown',e=>{if(e.key==='Escape')closeModal()});
</script>
